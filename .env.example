# 選填：OpenAI 翻譯（品質較佳）
OPENAI_API_KEY=

# google | openai
TRANSLATOR=google

# 每週抓取篇數上限
WEEKLY_ARTICLE_LIMIT=6
VOCAB_PER_ARTICLE=15

# 資料庫路徑（預設 data/toeic800.db）
# TOEIC800_DB=

# 種子 DB：主 DB 不存在時自動複製（可 commit 到 Git 供部署共用）
# TOEIC800_SEED=data/toeic800.seed.db

# 首次啟動且 DB 為空時自動抓取（true | false）
# AUTO_BOOTSTRAP_NEWS=true

# Cambridge Dictionary 查詢（單字釋義／例句）
# CAMBRIDGE_DICT_ENABLED=true
# CAMBRIDGE_REQUEST_GAP_SEC=1.2
